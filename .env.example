# ===== JWT (جلسات المنصة — sign / verify عبر shared/middleware/auth) =====
ERVENOW_JWT_SECRET=change_this_super_secret_key

# ===== SERVER =====
PORT=4000
NODE_ENV=development

# ===== SECURITY (نفس ERVENOW_INTERNAL_KEY في كبسار-backend) =====
INTERNAL_API_KEY=ضع_نفس_قيمة_ERVENOW_INTERNAL_KEY_في_كبسار

# ===== PUBLIC =====
ERVENOW_PUBLIC_URL=http://localhost:4000

