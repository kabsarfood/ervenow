PORT=4000
SUPABASE_URL=https://pnpcplpfktsujuhfpbny.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
# مطلوب لـ OTP + JWT (حفظ المستخدم وطلبات API)
SUPABASE_SERVICE_ROLE_KEY=

# رمز دخول ثابت للتطوير (افتراضي 12345، بدون واتساب). للإنتاج مع OTP عشوائي + واتساب:
# USE_RANDOM_OTP=true
# يمكن تغيير الرمز الثابت: FIXED_LOGIN_CODE=12345

# جلسة المنصة (وقّع عشوائي قوي)
ERVENOW_JWT_SECRET=change_me_to_a_long_random_string
# متوافق مع الإصدارات السابقة:
# ERWENOW_JWT_SECRET=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# مثال: +14155238886 أو whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=

# رقم واتساب الإدارة (أرقام فقط، بدون +) لإشعارات طلبات تسجيل المتاجر
ERVENOW_ADMIN_WHATSAPP=
# ERWENOW_ADMIN_WHATSAPP=

# دلو Supabase Storage لمرفقات السجل التجاري (افتراضي: erwenow-store-registrations)
# ERVENOW_STORE_FILES_BUCKET=erwenow-store-registrations
# ERWENOW_STORE_FILES_BUCKET=erwenow-store-registrations

# عند غياب TWILIO_* يعيد الخادم الرمز في الحقل devOtp (مناسب للتجربة).
# مع Twilio مضبوط: ضع true لإظهار الرمز في الاستجابة أيضاً (تصحيح فقط).
# ALLOW_DEV_OTP=true

# ضريبة على عمولة المنصة فقط (مثال السعودية 15% = 0.15). 0 = تعطيل
# ERVENOW_PLATFORM_VAT_ON_COMMISSION_RATE=0.15
# ERWENOW_PLATFORM_VAT_ON_COMMISSION_RATE=0.15
